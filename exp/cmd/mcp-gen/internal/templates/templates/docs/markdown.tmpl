## Quick Start

### Client Usage

{{if eq .Language "go"}}
```go
package main

import (
    "context"
    "fmt"
    "log"
    
    "github.com/tmc/mcp"
    "{{.Config.Go.ModulePath}}"
)

func main() {
    // Create client
    transport := mcp.StdioTransport()
    client, err := {{.Package}}.New{{.Package | toPascalCase}}Client(transport)
    if err != nil {
        log.Fatalf("Failed to create client: %v", err)
    }
    defer client.Close()
    
    // Initialize
    ctx := context.Background()
    clientInfo := mcp.Implementation{
        Name:    "my-client",
        Version: "1.0.0",
    }
    
    err = client.Initialize(ctx, clientInfo)
    if err != nil {
        log.Fatalf("Failed to initialize: %v", err)
    }
    
    // Use tools
    {{range .Tools}}
    {{if eq @index 0}}
    input := &{{$.Package}}.{{.Name | toPascalCase}}Input{
        // Set input fields
    }
    
    result, err := client.{{.Name | toPascalCase}}(ctx, input)
    if err != nil {
        log.Fatalf("Tool failed: %v", err)
    }
    
    fmt.Printf("Result: %v\n", result)
    {{end}}
    {{end}}
}
```
