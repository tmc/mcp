// HealthCheck performs a comprehensive health check
func (c *{{.Client.Name}}) HealthCheck(ctx context.Context) error {
	// Test basic connectivity
	if err := c.Ping(ctx); err != nil {
		return fmt.Errorf("ping failed: %w", err)
	}
	
	// Test tool availability
	tools, err := c.GetAvailableTools(ctx)
	if err != nil {
		return fmt.Errorf("failed to get available tools: %w", err)
	}
	
	expectedTools := []string{
		{{range .Tools}}"{{.Name}}",
		{{end}}
	}
	
	availableTools := make(map[string]bool)
	for _, tool := range tools {
		availableTools[tool.Name] = true
	}
	
	for _, expected := range expectedTools {
		if !availableTools[expected] {
			return fmt.Errorf("expected tool %s not available", expected)
		}
	}
	
	return nil
}

