// New{{.Client.Name}} creates a new {{.Client.Name}} instance
func New{{.Client.Name}}(transport mcp.Transport) (*{{.Client.Name}}, error) {
	client, err := mcp.NewClient(transport)
	if err != nil {
		return nil, fmt.Errorf("failed to create MCP client: %w", err)
	}
	
	return &{{.Client.Name}}{
		client: client,
	}, nil
}

// Initialize initializes the MCP client connection
func (c *{{.Client.Name}}) Initialize(ctx context.Context, clientInfo mcp.Implementation) error {
	initReq := mcp.InitializeRequest{
		ProtocolVersion: mcp.LATEST_PROTOCOL_VERSION,
		Capabilities: mcp.ClientCapabilities{
			Experimental: map[string]interface{}{},
			Sampling:     map[string]interface{}{},
		},
		ClientInfo: clientInfo,
	}
	
	_, err := c.client.Initialize(ctx, initReq)
	if err != nil {
		return fmt.Errorf("failed to initialize client: %w", err)
	}
	
	return nil
}

// Close closes the client connection
func (c *{{.Client.Name}}) Close() error {
	return c.client.Close()
}

