// Error handling utilities

// IsToolError checks if an error is a tool-specific error
func IsToolError(err error) bool {
	// Check if error is from tool execution
	return strings.Contains(err.Error(), "tool error")
}

// IsConnectionError checks if an error is a connection-related error
func IsConnectionError(err error) bool {
	// Check if error is from connection issues
	return strings.Contains(err.Error(), "connection") || 
	       strings.Contains(err.Error(), "transport")
}

// IsTimeoutError checks if an error is a timeout error
func IsTimeoutError(err error) bool {
	return strings.Contains(err.Error(), "timeout") ||
	       strings.Contains(err.Error(), "deadline exceeded")
}

// Utility functions for common operations

// ExecuteWithRetry executes a function with retry logic
func (c *{{.Client.Name}}) ExecuteWithRetry(ctx context.Context, fn func() error, maxRetries int) error {
	var lastErr error
	
	for i := 0; i <= maxRetries; i++ {
		if i > 0 {
			// Exponential backoff
			backoff := time.Duration(i*i) * time.Second
			select {
			case <-ctx.Done():
				return ctx.Err()
			case <-time.After(backoff):
			}
		}
		
		if err := fn(); err != nil {
			lastErr = err
			if !IsConnectionError(err) && !IsTimeoutError(err) {
				// Don't retry non-transient errors
				return err
			}
			continue
		}
		
		return nil
	}
	
	return fmt.Errorf("max retries exceeded, last error: %w", lastErr)
}

// BatchExecute executes multiple tool calls in sequence
func (c *{{.Client.Name}}) BatchExecute(ctx context.Context, requests []BatchRequest) ([]BatchResult, error) {
	results := make([]BatchResult, len(requests))
	
	for i, req := range requests {
		result, err := c.executeBatchRequest(ctx, req)
		results[i] = BatchResult{
			Index:  i,
			Result: result,
			Error:  err,
		}
	}
	
	return results, nil
}

