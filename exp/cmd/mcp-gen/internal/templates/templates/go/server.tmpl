		Name:        "{{.Name}}",
		Description: "{{.Description}}",
		InputSchema: json.RawMessage(`{{.InputSchema | json}}`),
	}
	
	s.server.RegisterTool(tool, s.handle{{.Name | toPascalCase}})
}

// handle{{.Name | toPascalCase}} handles the {{.Name}} tool execution
func (s *{{.Server.Name}}) handle{{.Name | toPascalCase}}(ctx context.Context, req mcp.CallToolRequest) (*mcp.CallToolResult, error) {
	// Parse input
	var input {{.Name | toPascalCase}}Input
	if len(req.Arguments) > 0 {
		if err := json.Unmarshal(req.Arguments, &input); err != nil {
			return &mcp.CallToolResult{
				IsError: true,
				Content: []interface{}{
					map[string]interface{}{
						"type": "text",
						"text": fmt.Sprintf("Invalid input for tool {{.Name}}: %v", err),
					},
				},
			}, nil
		}
	}
	
	// Execute tool logic
	output, err := s.execute{{.Name | toPascalCase}}(ctx, &input)
	if err != nil {
		return &mcp.CallToolResult{
			IsError: true,
			Content: []interface{}{
				map[string]interface{}{
					"type": "text",
					"text": fmt.Sprintf("Tool {{.Name}} error: %v", err),
				},
			},
		}, nil
	}
	
	// Marshal output
	outputJSON, err := json.Marshal(output)
	if err != nil {
		return &mcp.CallToolResult{
			IsError: true,
			Content: []interface{}{
				map[string]interface{}{
					"type": "text",
					"text": fmt.Sprintf("Failed to marshal output for tool {{.Name}}: %v", err),
				},
			},
		}, nil
	}
	
	return &mcp.CallToolResult{
		Content: []interface{}{
			map[string]interface{}{
				"type": "text",
				"text": string(outputJSON),
			},
		},
	}, nil
}

