// Mock transport for testing
type mockTransport struct {
	responses map[string]interface{}
	delay     time.Duration
	failCount int
	callCount int
}

func (m *mockTransport) Call(method string, params interface{}) (interface{}, error) {
	m.callCount++
	
	if m.failCount > 0 && m.callCount <= m.failCount {
		return nil, fmt.Errorf("mock transport failure")
	}
	
	if m.delay > 0 {
		time.Sleep(m.delay)
	}
	
	if response, exists := m.responses[method]; exists {
		return response, nil
	}
	
	return map[string]interface{}{
		"result": "mock response",
	}, nil
}

func (m *mockTransport) Close() error {
	return nil
}

